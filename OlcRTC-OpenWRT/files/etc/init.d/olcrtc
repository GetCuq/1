#!/bin/sh /etc/rc.common
# Скрипт инициализации OlcRTC для OpenWRT
# Часть проекта OlcRTC-OpenWRT

USE_PROCD=1
START=95
STOP=10

PROG=/usr/bin/olcrtc
PIDFILE=/var/run/olcrtc.pid
LOGTAG="olcrtc"

start_service() {
    local provider room_id key socks_port enabled

    config_load olcrtc
    config_get provider   config provider   'telemost'
    config_get room_id    config room_id    ''
    config_get key        config key        ''
    config_get socks_port config socks_port '1080'
    config_get enabled    config enabled    '0'

    if [ "$enabled" != "1" ]; then
        logger -t "$LOGTAG" "Автозапуск отключён, пропускаем старт"
        return 0
    fi

    if [ -z "$room_id" ] || [ -z "$key" ]; then
        logger -t "$LOGTAG" "Ошибка: не заданы Room ID или ключ — запуск невозможен"
        return 1
    fi

    if [ ! -x "$PROG" ]; then
        logger -t "$LOGTAG" "Ошибка: бинарник $PROG не найден или не исполняемый"
        return 1
    fi

    logger -t "$LOGTAG" "Запуск клиента: провайдер=$provider, порт=$socks_port"

    procd_open_instance
    procd_set_param command "$PROG" \
        -mode cnc \
        -provider "$provider" \
        -id "$room_id" \
        -key "$key" \
        -socks-port "$socks_port"
    procd_set_param respawn 3600 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile "$PIDFILE"
    procd_close_instance
}

stop_service() {
    logger -t "$LOGTAG" "Остановка клиента"
}

service_triggers() {
    procd_add_reload_trigger "olcrtc"
}

reload_service() {
    stop
    start
}
